{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hiivmind.dev/schemas/workflow.json",
  "$comment": "Schema version 2.1 - Added definitions block for external type references",
  "title": "Blueprint Workflow Schema",
  "description": "JSON Schema for hiivmind-blueprint workflow.yaml files",
  "type": "object",
  "required": ["name", "version", "start_node", "nodes", "endings"],
  "properties": {
    "name": {
      "type": "string",
      "description": "Workflow name (used as identifier)"
    },
    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$",
      "description": "Semantic version (e.g., 1.0.0)"
    },
    "description": {
      "type": "string",
      "description": "Brief description of the workflow's purpose"
    },
    "definitions": {
      "$ref": "#/$defs/definitions",
      "description": "External type definitions source (optional - defaults to embedded definitions)"
    },
    "entry_preconditions": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/precondition"
      },
      "description": "Conditions that must be true before workflow can start"
    },
    "initial_state": {
      "type": "object",
      "description": "Initial state values when workflow begins. Note: Some fields are computed at runtime and not declared here - see $comment for details.",
      "$comment": "Runtime fields (computed at initialization, not declared): interface (string: 'claude_code' or 'claude_ai' based on AskUserQuestion tool availability), workflow_name, workflow_version, current_node, previous_node, history, user_responses, checkpoints",
      "properties": {
        "phase": { "type": "string" },
        "flags": {
          "type": "object",
          "additionalProperties": { "type": "boolean" }
        },
        "computed": { "type": "object" }
      },
      "additionalProperties": true
    },
    "imports": {
      "type": "object",
      "description": "External YAML files to load at workflow start",
      "additionalProperties": { "type": "string" }
    },
    "start_node": {
      "type": "string",
      "description": "ID of the first node to execute"
    },
    "nodes": {
      "type": "object",
      "description": "Map of node IDs to node definitions",
      "additionalProperties": {
        "$ref": "#/$defs/node"
      }
    },
    "endings": {
      "type": "object",
      "description": "Map of ending IDs to ending definitions",
      "additionalProperties": {
        "$ref": "#/$defs/ending"
      }
    }
  },
  "$defs": {
    "node": {
      "type": "object",
      "description": "A workflow node definition",
      "required": ["type"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["action", "conditional", "user_prompt", "validation_gate", "reference"],
          "description": "Node type"
        },
        "description": {
          "type": "string",
          "description": "Human-readable description of what this node does"
        }
      },
      "allOf": [
        {
          "if": { "properties": { "type": { "const": "action" } } },
          "then": { "$ref": "#/$defs/action_node" }
        },
        {
          "if": { "properties": { "type": { "const": "conditional" } } },
          "then": { "$ref": "#/$defs/conditional_node" }
        },
        {
          "if": { "properties": { "type": { "const": "user_prompt" } } },
          "then": { "$ref": "#/$defs/user_prompt_node" }
        },
        {
          "if": { "properties": { "type": { "const": "validation_gate" } } },
          "then": { "$ref": "#/$defs/validation_gate_node" }
        },
        {
          "if": { "properties": { "type": { "const": "reference" } } },
          "then": { "$ref": "#/$defs/reference_node" }
        }
      ]
    },
    "action_node": {
      "type": "object",
      "required": ["actions", "on_success", "on_failure"],
      "properties": {
        "type": { "const": "action" },
        "description": { "type": "string" },
        "actions": {
          "type": "array",
          "items": { "$ref": "#/$defs/consequence" },
          "minItems": 1,
          "description": "Consequences to execute sequentially"
        },
        "on_success": {
          "type": "string",
          "description": "Node or ending to transition to on success"
        },
        "on_failure": {
          "type": "string",
          "description": "Node or ending to transition to on failure"
        }
      }
    },
    "conditional_node": {
      "type": "object",
      "required": ["condition", "branches"],
      "properties": {
        "type": { "const": "conditional" },
        "description": { "type": "string" },
        "condition": {
          "$ref": "#/$defs/precondition",
          "description": "Condition to evaluate"
        },
        "branches": {
          "type": "object",
          "required": ["true", "false"],
          "properties": {
            "true": {
              "type": "string",
              "description": "Node to transition to if condition is true"
            },
            "false": {
              "type": "string",
              "description": "Node to transition to if condition is false"
            }
          },
          "additionalProperties": false
        }
      }
    },
    "user_prompt_node": {
      "type": "object",
      "required": ["prompt", "on_response"],
      "properties": {
        "type": { "const": "user_prompt" },
        "description": { "type": "string" },
        "prompt": {
          "$ref": "#/$defs/prompt",
          "description": "Prompt configuration"
        },
        "on_response": {
          "type": "object",
          "description": "Map of option IDs to response handlers",
          "additionalProperties": {
            "$ref": "#/$defs/response_handler"
          }
        }
      }
    },
    "validation_gate_node": {
      "type": "object",
      "required": ["validations", "on_valid", "on_invalid"],
      "properties": {
        "type": { "const": "validation_gate" },
        "description": { "type": "string" },
        "validations": {
          "type": "array",
          "items": {
            "allOf": [
              { "$ref": "#/$defs/precondition" },
              {
                "properties": {
                  "error_message": {
                    "type": "string",
                    "description": "Error message if validation fails"
                  }
                }
              }
            ]
          },
          "minItems": 1,
          "description": "Preconditions to validate"
        },
        "on_valid": {
          "type": "string",
          "description": "Node to transition to if all validations pass"
        },
        "on_invalid": {
          "type": "string",
          "description": "Node to transition to if any validation fails"
        }
      }
    },
    "reference_node": {
      "type": "object",
      "required": ["doc", "next_node"],
      "properties": {
        "type": { "const": "reference" },
        "description": { "type": "string" },
        "doc": {
          "type": "string",
          "description": "Path to pattern document"
        },
        "section": {
          "type": "string",
          "description": "Specific section to execute"
        },
        "context": {
          "type": "object",
          "description": "Variables to pass to the pattern",
          "additionalProperties": true
        },
        "next_node": {
          "type": "string",
          "description": "Node to transition to after reference executes"
        }
      }
    },
    "prompt": {
      "type": "object",
      "required": ["question", "header", "options"],
      "properties": {
        "question": {
          "type": "string",
          "description": "Question to ask the user"
        },
        "header": {
          "type": "string",
          "maxLength": 12,
          "description": "Short header/tag (max 12 characters)"
        },
        "options": {
          "type": "array",
          "items": { "$ref": "#/$defs/prompt_option" },
          "minItems": 2,
          "maxItems": 4,
          "description": "Available choices (2-4 options)"
        },
        "options_from_state": {
          "type": "string",
          "description": "State field containing dynamic options"
        },
        "option_template": {
          "type": "object",
          "properties": {
            "label": { "type": "string" },
            "description": { "type": "string" }
          }
        }
      }
    },
    "prompt_option": {
      "type": "object",
      "required": ["id", "label"],
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique option identifier"
        },
        "label": {
          "type": "string",
          "description": "Display label"
        },
        "description": {
          "type": "string",
          "description": "Option description"
        }
      },
      "additionalProperties": false
    },
    "response_handler": {
      "type": "object",
      "properties": {
        "consequence": {
          "type": "array",
          "items": { "$ref": "#/$defs/consequence" },
          "description": "Consequences to apply when this option is selected"
        },
        "next_node": {
          "type": "string",
          "description": "Node to transition to"
        }
      }
    },
    "ending": {
      "type": "object",
      "required": ["type"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["success", "error"],
          "description": "Ending type"
        },
        "message": {
          "type": "string",
          "description": "Message to display (supports ${} interpolation)"
        },
        "summary": {
          "type": "object",
          "description": "Summary data to display",
          "additionalProperties": true
        },
        "details": {
          "type": "string",
          "description": "Additional details for error endings"
        },
        "recovery": {
          "type": "string",
          "description": "Skill to suggest for recovery"
        }
      }
    },
    "precondition": {
      "type": "object",
      "description": "A workflow precondition (boolean check). The schema validates structure only - precondition type validation is delegated to the definitions in lib/preconditions/definitions/",
      "$comment": "Schema version 2.0 - Precondition-agnostic design. Type validation against lib/preconditions/definitions/index.yaml at runtime.",
      "required": ["type"],
      "properties": {
        "type": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_]*$",
          "description": "Precondition type identifier (e.g., file_exists, flag_set, all_of). See lib/preconditions/definitions/index.yaml for available types."
        },
        "error_message": {
          "type": "string",
          "description": "Error message to display if precondition fails (used in validation gates)"
        }
      },
      "additionalProperties": true
    },
    "consequence": {
      "type": "object",
      "description": "A workflow consequence (action to execute). The schema validates structure only - consequence type validation is delegated to the definitions in lib/consequences/definitions/",
      "$comment": "Schema version 2.0 - Consequence-agnostic design. Type validation against lib/consequences/definitions/index.yaml at runtime.",
      "required": ["type"],
      "properties": {
        "type": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_]*$",
          "description": "Consequence type identifier (e.g., set_state, clone_repo, run_python). See lib/consequences/definitions/index.yaml for available types."
        }
      },
      "additionalProperties": true
    },
    "definitions": {
      "type": "object",
      "description": "External type definitions source configuration. Allows workflows to reference type definitions from URLs or local paths.",
      "$comment": "Schema version 1.0 - External type definitions support (GitHub Actions-style references)",
      "properties": {
        "source": {
          "description": "Type definitions source. Can be a URL to bundle.yaml, 'local' for embedded definitions, or a shorthand like 'hiivmind/hiivmind-blueprint-types@v1'",
          "oneOf": [
            {
              "type": "string",
              "format": "uri",
              "description": "Direct URL to bundle.yaml"
            },
            {
              "const": "local",
              "description": "Use local embedded definitions"
            },
            {
              "type": "string",
              "pattern": "^[a-zA-Z0-9_-]+/[a-zA-Z0-9_-]+@v?[0-9\\.]+$",
              "description": "Shorthand: owner/repo@version"
            }
          ]
        },
        "path": {
          "type": "string",
          "description": "Local path to embedded definitions (required when source is 'local')"
        },
        "base_url": {
          "type": "string",
          "format": "uri",
          "description": "Base URL for selective loading"
        },
        "consequences": {
          "type": "string",
          "description": "Path to consequences index.yaml relative to base_url"
        },
        "preconditions": {
          "type": "string",
          "description": "Path to preconditions index.yaml relative to base_url"
        },
        "extensions": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Additional type definition packages to load"
        },
        "fallback": {
          "type": "string",
          "enum": ["error", "warn", "embedded"],
          "default": "error",
          "description": "Behavior when remote fetch fails"
        }
      },
      "additionalProperties": false
    }
  }
}
