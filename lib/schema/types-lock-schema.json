{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/hiivmind/hiivmind-blueprint/lib/schema/types-lock-schema.json",
  "title": "Blueprint Types Lock File",
  "description": "Schema for .hiivmind/blueprint/types.lock version pinning file",
  "type": "object",
  "required": ["schema", "generated_at", "generated_by", "engine", "types"],
  "properties": {
    "schema": {
      "type": "string",
      "description": "Lock file schema version",
      "pattern": "^\\d+\\.\\d+$",
      "examples": ["1.0"]
    },
    "generated_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp when lock file was generated"
    },
    "generated_by": {
      "type": "string",
      "description": "Tool and version that generated this lock file",
      "pattern": "^hiivmind-blueprint v\\d+\\.\\d+\\.\\d+$",
      "examples": ["hiivmind-blueprint v1.1.0"]
    },
    "engine": {
      "type": "object",
      "description": "Pinned engine version information",
      "required": ["version", "source"],
      "properties": {
        "version": {
          "type": "string",
          "description": "Semantic version of the engine",
          "pattern": "^\\d+\\.\\d+\\.\\d+$",
          "examples": ["1.1.0"]
        },
        "sha256": {
          "type": "string",
          "description": "SHA256 hash of engine.md for integrity verification",
          "pattern": "^[a-f0-9]{64}$"
        },
        "source": {
          "type": "string",
          "description": "Source reference for the engine",
          "pattern": "^[a-zA-Z0-9_-]+/[a-zA-Z0-9_-]+@v?[\\d.]+$",
          "examples": ["hiivmind/hiivmind-blueprint@v1.1.0"]
        }
      },
      "additionalProperties": false
    },
    "types": {
      "type": "object",
      "description": "Map of type source to version information",
      "additionalProperties": {
        "type": "object",
        "required": ["requested", "resolved"],
        "properties": {
          "requested": {
            "type": "string",
            "description": "Version request pattern from workflow definitions",
            "pattern": "^@v?[\\d.]+$|^@latest$",
            "examples": ["@v1", "@v1.3", "@v1.3.2", "@latest"]
          },
          "resolved": {
            "type": "string",
            "description": "Actual resolved version",
            "pattern": "^v?\\d+\\.\\d+\\.\\d+$",
            "examples": ["v1.3.2", "1.3.2"]
          },
          "sha256": {
            "type": "string",
            "description": "SHA256 hash of bundle.yaml for integrity verification",
            "pattern": "^[a-f0-9]{64}$"
          },
          "fetched_at": {
            "type": "string",
            "format": "date-time",
            "description": "ISO 8601 timestamp when this version was fetched"
          },
          "url": {
            "type": "string",
            "format": "uri",
            "description": "URL from which the bundle was fetched"
          }
        },
        "additionalProperties": false
      },
      "propertyNames": {
        "pattern": "^[a-zA-Z0-9_-]+/[a-zA-Z0-9_-]+$"
      }
    }
  },
  "additionalProperties": false,
  "examples": [
    {
      "schema": "1.0",
      "generated_at": "2026-01-27T12:00:00Z",
      "generated_by": "hiivmind-blueprint v1.1.0",
      "engine": {
        "version": "1.1.0",
        "sha256": "abc123def456789abc123def456789abc123def456789abc123def456789abcd",
        "source": "hiivmind/hiivmind-blueprint@v1.1.0"
      },
      "types": {
        "hiivmind/hiivmind-blueprint-types": {
          "requested": "@v1",
          "resolved": "v1.3.2",
          "sha256": "def456abc123789def456abc123789def456abc123789def456abc123789defg",
          "fetched_at": "2026-01-27T05:30:00Z"
        }
      }
    }
  ]
}
