# Workflow Template
#
# This template is used by hiivmind-blueprint to generate workflow.yaml files.
# Placeholders use {{placeholder}} syntax and are replaced at generation time.
#
# Schema: https://raw.githubusercontent.com/hiivmind/hiivmind-blueprint-lib/main/schema/authoring/workflow.json
# Version: 3.0 (local definitions, no remote loading)
#
# Type definitions are resolved from .hiivmind/blueprint/definitions.yaml
# Authoring-time reference: see hiivmind-blueprint/patterns/authoring-guide.md for setup instructions.

# ============================================================================
# WORKFLOW IDENTITY
# ============================================================================

name: "{{skill_id}}"
version: "1.0.0"
description: >
  {{description}}

# ============================================================================
# ENTRY PRECONDITIONS
# ============================================================================
# All conditions must pass for workflow to start.
# Generated from: tools mentioned, files required, prerequisites in prose.

entry_preconditions:
  # {{#entry_preconditions}}
  # - type: {{type}}
  #   {{#params}}{{key}}: {{value}}{{/params}}
  # {{/entry_preconditions}}
  - type: tool_check
    tool: git
    capability: available

# ============================================================================
# INITIAL STATE
# ============================================================================
# Runtime state initialized when workflow starts.
# Fields from analysis: {{state_variables}}

initial_state:
  phase: "start"
  flags:
    initialized: false
  computed: {}

  # ──────────────────────────────────────────────────────────────────────────
  # Output Configuration (unified logging + display)
  # ──────────────────────────────────────────────────────────────────────────
  # Schema: schema/config/output-config.json
  output:
    level: "normal"           # silent | quiet | normal | verbose | debug
    log_enabled: true
    log_format: "yaml"
    log_location: ".logs/"

  # ──────────────────────────────────────────────────────────────────────────
  # Prompts Configuration (multi-modal)
  # ──────────────────────────────────────────────────────────────────────────
  # Schema: schema/config/prompts-config.json
  prompts:
    interface: "auto"         # auto | claude_code | web | api | agent
    modes:
      claude_code: "interactive"
      web: "forms"
      api: "structured"
      agent: "autonomous"
    tabular:
      match_strategy: "prefix"
      other_handler: "prompt"
    autonomous:
      strategy: "best_match"
      confidence_threshold: 0.7

# ============================================================================
# START NODE
# ============================================================================

start_node: {{start_node}}

# ============================================================================
# NODES
# ============================================================================
# Workflow graph. Each node executes and routes to next node or ending.
# Node types: action, conditional, user_prompt

nodes:
  # --------------------------------------------------------------------------
  # Action Node Template
  # --------------------------------------------------------------------------
  # action_node_name:
  #   type: action
  #   description: "What this node does"
  #   actions:
  #     - type: {{consequence_type}}
  #       {{#params}}{{key}}: {{value}}{{/params}}
  #   on_success: next_node_name
  #   on_failure: error_node_name

  # --------------------------------------------------------------------------
  # Conditional Node Template
  # --------------------------------------------------------------------------
  # conditional_node_name:
  #   type: conditional
  #   description: "Decision point description"
  #   condition:
  #     type: {{precondition_type}}
  #     {{#params}}{{key}}: {{value}}{{/params}}
  #   branches:
  #     on_true: node_when_true
  #     on_false: node_when_false

  # --------------------------------------------------------------------------
  # User Prompt Node Template
  # --------------------------------------------------------------------------
  # user_prompt_node_name:
  #   type: user_prompt
  #   prompt:
  #     question: "{{question_text}}"
  #     header: "{{header}}"  # Max 12 chars
  #     options:
  #       - id: option_id
  #         label: "Option Label"
  #         description: "What this option does"
  #   on_response:
  #     option_id:
  #       consequence:
  #         - type: mutate_state
  #           operation: set
  #           field: selected_option
  #           value: option_id
  #       next_node: next_node_name
  #
  # Dynamic options from state:
  # user_prompt_dynamic:
  #   type: user_prompt
  #   prompt:
  #     question: "Select an item"
  #     header: "Items"
  #     options_from_state: "computed.items"
  #     options:
  #       id: "item.id"
  #       label: "item.name"
  #       description: "item.desc"
  #   on_response:
  #     selected:
  #       next_node: process_item

  # --------------------------------------------------------------------------
  # Conditional with Audit Mode (replaces deprecated validation_gate)
  # --------------------------------------------------------------------------
  # validate_prerequisites:
  #   type: conditional
  #   description: "Validate prerequisites"
  #   condition:
  #     type: composite
  #     operator: all
  #     conditions:
  #       - type: path_check
  #         path: "${config_path}"
  #         check: is_file
  #       - type: tool_check
  #         tool: "git"
  #         capability: available
  #   audit:
  #     enabled: true
  #     output: computed.validation_errors
  #     messages:
  #       path_check: "Required config not found: ${config_path}"
  #       tool_check: "Git is required but not installed"
  #   branches:
  #     on_true: proceed_node
  #     on_false: validation_failed

  # --------------------------------------------------------------------------
  # Generated Nodes
  # --------------------------------------------------------------------------
  {{#nodes}}
  {{id}}:
    type: {{type}}
    {{#description}}
    description: "{{description}}"
    {{/description}}
    {{#if_action}}
    actions:
      {{#actions}}
      - type: {{type}}
        {{#params}}
        {{key}}: {{value}}
        {{/params}}
      {{/actions}}
    on_success: {{on_success}}
    on_failure: {{on_failure}}
    {{/if_action}}
    {{#if_conditional}}
    condition:
      type: {{condition_type}}
      {{#condition_params}}
      {{key}}: {{value}}
      {{/condition_params}}
    branches:
      on_true: {{branch_true}}
      on_false: {{branch_false}}
    {{/if_conditional}}
    {{#if_user_prompt}}
    prompt:
      question: "{{question}}"
      header: "{{header}}"
      options:
        {{#options}}
        - id: {{id}}
          label: "{{label}}"
          description: "{{description}}"
        {{/options}}
    on_response:
      {{#responses}}
      {{id}}:
        {{#consequence}}
        consequence:
          {{#actions}}
          - type: {{type}}
            {{#params}}
            {{key}}: {{value}}
            {{/params}}
          {{/actions}}
        {{/consequence}}
        next_node: {{next_node}}
      {{/responses}}
    {{/if_user_prompt}}
    {{#if_conditional_audit}}
    condition:
      type: composite
      operator: all
      conditions:
        {{#validations}}
        - type: {{type}}
          {{#params}}
          {{key}}: {{value}}
          {{/params}}
        {{/validations}}
    audit:
      enabled: true
      output: computed.validation_errors
      messages:
        {{#validations}}
        {{type}}: "{{error_message}}"
        {{/validations}}
    branches:
      on_true: {{on_valid}}
      on_false: {{on_invalid}}
    {{/if_conditional_audit}}

  {{/nodes}}

# ============================================================================
# ENDINGS
# ============================================================================
# Terminal states. All paths must eventually reach an ending.

endings:
  success:
    type: success
    message: "{{success_message}}"
    {{#success_summary}}
    summary:
      {{#fields}}
      {{key}}: "${computed.{{value}}}"
      {{/fields}}
    {{/success_summary}}

  {{#error_endings}}
  {{id}}:
    type: error
    message: "{{message}}"
    {{#recovery}}
    recovery: "{{recovery}}"
    {{/recovery}}
    {{#details}}
    details: "{{details}}"
    {{/details}}

  {{/error_endings}}
  cancelled:
    type: cancelled
    message: "Operation cancelled by user"

  # Safety ending - route here when Claude detects harmful intent
  error_safety:
    type: error
    category: safety
    message: "I can't help with that request."
    recovery:
      suggestion: "Please rephrase your request to focus on legitimate use cases."
